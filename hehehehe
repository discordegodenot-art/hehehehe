local function CreateModernBindBox(parent, defaultText)
    local box = Instance.new("TextBox")
    box.Size = UDim2.new(0, 75, 1, 0)
    box.Position = UDim2.new(1, -75, 0, 0)
    box.Text = defaultText:upper()
    box.BackgroundColor3 = Theme.CardBg
    box.TextColor3 = Theme.TextActive
    box.Font = Enum.Font.GothamBold
    box.TextSize = 13
    box.BorderSizePixel = 0
    box.ClearTextOnFocus = true
    box.Parent = parent
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = box
    
    box.FocusLost:Connect(function()
        box.Text = box.Text:upper()
    end)
    
    return box
end

local function CreateModernButton(parent, text, color, sizeXWidth, positionX, order)
    local btn = Instance.new("TextButton")
    btn.Size = sizeXWidth or UDim2.new(1, -85, 1, 0)
    btn.Position = positionX or UDim2.new(0, 0, 0, 0)
    btn.Text = text
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 13
    btn.BackgroundColor3 = color or Theme.BtnDefault
    btn.TextColor3 = Theme.TextActive
    btn.BorderSizePixel = 0
    if order then btn.LayoutOrder = order end
    btn.Parent = parent
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = btn
    return btn
end

