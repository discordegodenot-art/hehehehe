local function ListenForBindChange(box, bindKey)
    box.FocusLost:Connect(function()
        local text = box.Text:upper():gsub("%s+", "")
        if text ~= "" then Binds[bindKey] = text box.Text = text else box.Text = Binds[bindKey] end
    end)
end

