--------------------------------------------------------------------------------
-- LOOPS RESTRUTURADOS DO MOTOR (HEARTBEAT/STEPPED/RENDER)
--------------------------------------------------------------------------------
RunService.Stepped:Connect(function()
    if noclip_active and player.Character then
        for _, part in ipairs(player.Character:GetDescendants()) do if part:IsA("BasePart") then part.CanCollide = false end end
    end
    
    if fling_active and player.Character then
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0) hrp.AssemblyAngularVelocity = Vector3.new(0, 99999, 0) end
    end
end)

RunService.Heartbeat:Connect(function(delta)
    local char = player.Character if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    
    if humanoid then
        if walkspeed_bypass_active then humanoid.WalkSpeed = customWalkSpeed end
        if jumppower_bypass_active then humanoid.UseJumpPower = true humanoid.JumpPower = customJumpPower end
    end
    
    if fly_active and hrp and humanoid then
        local flyVelocity = Vector3.new(0, 0, 0) local lookCFrame = Camera.CFrame
        if UIS:IsKeyDown(Enum.KeyCode.W) then flyVelocity = flyVelocity + lookCFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then flyVelocity = flyVelocity - lookCFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then flyVelocity = flyVelocity - lookCFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then flyVelocity = flyVelocity + lookCFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.Space) then flyVelocity = flyVelocity + Vector3.new(0, 1, 0) end
        if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then flyVelocity = flyVelocity - Vector3.new(0, 1, 0) end
        if flyVelocity.Magnitude > 0 then hrp.AssemblyLinearVelocity = flyVelocity.Unit * customFlySpeed else hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0) end
    end
    
    if freecam_active then
        local camVelocity = Vector3.new(0, 0, 0) local lookCFrame = Camera.CFrame
        if UIS:IsKeyDown(Enum.KeyCode.W) then camVelocity = camVelocity + lookCFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then camVelocity = camVelocity - lookCFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then camVelocity = camVelocity + lookCFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then camVelocity = camVelocity - lookCFrame.RightVector end
        freecam_pos = freecam_pos + (camVelocity * delta * customFlySpeed)
        Camera.CFrame = CFrame.new(freecam_pos) * CFrame.fromEulerAnglesYXZ(freecam_rotY, freecam_rotX, 0)
    end
end)

RunService.RenderStepped:Connect(function()
    pcall(function()
        FOVCircle.Position = GetScreenCenter()
        FOVCircle.Radius = AimbotFOV.Radius
        FOVCircle.Color = AimbotFOV.Color
        FOVCircle.Thickness = AimbotFOV.Thickness
        FOVCircle.Visible = AimbotFOV.Visible
        FOVCircle.Transparency = AimbotFOV.Transparency
    end)

    if aimbot_active and aiming then
        local targetPart = GetClosestPlayerToCursor()
        if targetPart then Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPart.Position) end
    end
end)
