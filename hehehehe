local function UpdateTabVisuals(activeButton, activePage)
    local buttons = {Tab1Button, Tab2Button, Tab3Button, Tab4Button}
    local pages = {Page1, Page2, Page3, Page4}
    for i, btn in ipairs(buttons) do
        if btn == activeButton then
            btn.BackgroundColor3 = Theme.TabActive btn.TextColor3 = Theme.TextActive
            pages[i].Visible = true
        else
            btn.BackgroundColor3 = Theme.TabInactive btn.TextColor3 = Theme.TextMuted
            pages[i].Visible = false
        end
    end
end
