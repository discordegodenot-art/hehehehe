--------------------------------------------------------------------------------
-- Loop RenderStepped Principal (Renderização, Freecam, Fly, Travas God, AutoClick)
--------------------------------------------------------------------------------
RunService.RenderStepped:Connect(function(delta)
    if esp_active then
        for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer then ESP.UpdateESP(p) end end
    end

    if aimbot_active and aiming then
        local targetPart = GetClosestPlayerToCursor()
        if targetPart then Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPart.Position) end
    end

    if godmode_active and player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health < hum.MaxHealth then
            hum.Health = hum.MaxHealth
        end
    end

    -- LÓGICA DO AUTO CLICKER SUPER RÁPIDO
    if autoclick_active then
        -- Envia os sinais físicos de clique pressionado e solto de forma imediata
        VirtualInputManager:SendMouseButtonEvent(UIS:GetMouseLocation().X, UIS:GetMouseLocation().Y, 0, true, game, 0)
        VirtualInputManager:SendMouseButtonEvent(UIS:GetMouseLocation().X, UIS:GetMouseLocation().Y, 0, false, game, 0)
    end

    if freecam_active then
        Camera.CameraType = Enum.CameraType.Scriptable
        
        local camSpeed = tonumber(FlySpeedBox.Text) or 50
        local moveVector = Vector3.new(0, 0, 0)

        if UIS:IsKeyDown(Enum.KeyCode.W) then moveVector = moveVector + Camera.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then moveVector = moveVector - Camera.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then moveVector = moveVector - Camera.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then moveVector = moveVector + Camera.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.Space) then moveVector = moveVector + Vector3.new(0, 1, 0) end 
        if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then moveVector = moveVector - Vector3.new(0, 1, 0) end 

        freecam_pos = freecam_pos + (moveVector * camSpeed * delta)
        Camera.CFrame = CFrame.new(freecam_pos) * CFrame.Angles(0, freecam_rotX, 0) * CFrame.Angles(freecam_rotY, 0, 0)
    end

    if spectate_active and not freecam_active then
        local currentTarget = targetList[targetIndex]
        if currentTarget and currentTarget.Character then
            local targetHumanoid = currentTarget.Character:FindFirstChildOfClass("Humanoid")
            if targetHumanoid and targetHumanoid.Health > 0 then
                if Camera.CameraSubject ~= targetHumanoid then Camera.CameraSubject = targetHumanoid end
            else ChangeTarget(1) end
        else ChangeTarget(1) end
    end

    local character = player.Character
    if character then
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")

        if humanoid and humanoidRootPart then
            if freecam_active then
                humanoidRootPart.Velocity = Vector3.new(0,0,0)
                return
            end

            if jumppower_bypass_active then
                humanoid.UseJumpPower = true
                humanoid.JumpPower = customJumpPower
            end

            if fly_active or noclip_active then
                humanoid.PlatformStand = true
                humanoidRootPart.Velocity = Vector3.new(0, 0, 0)
                
                local moveVector = Vector3.new(0, 0, 0)
                local currentFlySpeed = tonumber(FlySpeedBox.Text) or 50

                if UIS:IsKeyDown(Enum.KeyCode.W) then moveVector = moveVector + Camera.CFrame.LookVector end
                if UIS:IsKeyDown(Enum.KeyCode.S) then moveVector = moveVector - Camera.CFrame.LookVector end
                if UIS:IsKeyDown(Enum.KeyCode.A) then moveVector = moveVector - Camera.CFrame.RightVector end
                if UIS:IsKeyDown(Enum.KeyCode.D) then moveVector = moveVector + Camera.CFrame.RightVector end
                if UIS:IsKeyDown(Enum.KeyCode.Space) then moveVector = moveVector + Vector3.new(0, 1, 0) end 
                if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then moveVector = moveVector - Vector3.new(0, 1, 0) end 

                if moveVector.Magnitude > 0 then 
                    humanoidRootPart.CFrame = humanoidRootPart.CFrame + moveVector.Unit * currentFlySpeed * delta
                end
            else
                if humanoid.PlatformStand then
                    humanoid.PlatformStand = false
                end
                
                if walkspeed_bypass_active and humanoid.MoveDirection.Magnitude > 0 then
                    local speedMultiplier = customWalkSpeed - 16
                    if speedMultiplier > 0 then
                        humanoidRootPart.CFrame = humanoidRootPart.CFrame + (humanoid.MoveDirection * (speedMultiplier * delta))
                    end
                end
            end
        end
    end
end)

--------------------------------------------------------------------------------
-- Código do esqueleto ESP Avançado Híbrido
--------------------------------------------------------------------------------
local Config = { SkeletonColor = Color3.fromRGB(180, 50, 50), Thickness = 2, Transparency = 0.4, DistanceFade = true, MaxDistance = 500 }
local function IsAlive(p) if not p or not p.Character then return false end local humanoid = p.Character:FindFirstChildOfClass("Humanoid") return humanoid and humanoid.Health > 0 end

function ESP.CreateESP(p)
    if p == LocalPlayer or not p or not p.Character then return end
    pcall(function()
        local character = p.Character; local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
        if not humanoidRootPart then return end
        if ESP[p] then ESP.RemoveESP(p) end
        
        local isR15 = character:FindFirstChild("UpperTorso") ~= nil
        ESP[p] = {lines = {}, isR15 = isR15}

        local parts = {
            Head = character:FindFirstChild("Head"),
            UpperTorso = character:FindFirstChild("UpperTorso"),
            LowerTorso = character:FindFirstChild("LowerTorso"),
            Torso = character:FindFirstChild("Torso"),
            LeftUpperArm = character:FindFirstChild("LeftUpperArm"),
            LeftLowerArm = character:FindFirstChild("LeftLowerArm"),
            LeftHand = character:FindFirstChild("LeftHand"),
            LeftArm = character:FindFirstChild("Left Arm"),
            RightUpperArm = character:FindFirstChild("RightUpperArm"),
            RightLowerArm = character:FindFirstChild("RightLowerArm"),
            RightHand = character:FindFirstChild("RightHand"),
            RightArm = character:FindFirstChild("Right Arm"),
            LeftUpperLeg = character:FindFirstChild("LeftUpperLeg"),
            LeftLowerLeg = character:FindFirstChild("LeftLowerLeg"),
            LeftFoot = character:FindFirstChild("LeftFoot"),
            LeftLeg = character:FindFirstChild("Left Leg"),
            RightUpperLeg = character:fromRGB(255,255,255) and character:FindFirstChild("RightUpperLeg"),
            RightLowerLeg = character:FindFirstChild("RightLowerLeg"),
            RightFoot = character:FindFirstChild("RightFoot"),
            RightLeg = character:FindFirstChild("Right Leg")
        }

        if isR15 then
            local connections = {
                {parts.Head, parts.UpperTorso},
                {parts.UpperTorso, parts.LowerTorso},
                {parts.UpperTorso, parts.LeftUpperArm}, {parts.LeftUpperArm, parts.LeftLowerArm}, {parts.LeftLowerArm, parts.LeftHand},
                {parts.UpperTorso, parts.RightUpperArm}, {parts.RightUpperArm, parts.RightLowerArm}, {parts.RightLowerArm, parts.RightHand},
                {parts.LowerTorso, parts.LeftUpperLeg}, {parts.LeftUpperLeg, parts.LeftLowerLeg}, {parts.LeftLowerLeg, parts.LeftFoot},
                {parts.LowerTorso, parts.RightUpperLeg}, {parts.RightUpperLeg, parts.RightLowerLeg}, {parts.RightLowerLeg, parts.RightFoot}
            }
            for _, conn in ipairs(connections) do
                if conn[1] and conn[2] then
                    local line = Drawing.new("Line")
                    line.Color = Config.SkeletonColor; line.Thickness = Config.Thickness; line.Transparency = Config.Transparency; line.Visible = esp_active
                    table.insert(ESP[p].lines, {line = line, type = "R15", part1 = conn[1], part2 = conn[2]})
                end
            end
        else
            for i = 1, 10 do
                local line = Drawing.new("Line")
                line.Color = Config.SkeletonColor; line.Thickness = Config.Thickness; line.Transparency = Config.Transparency; line.Visible = esp_active
                table.insert(ESP[p].lines, {line = line, type = "R6", id = i, parts = parts})
            end
        end
    end)
end

function ESP.UpdateESP(p)
    if not ESP[p] or not IsAlive(p) then return end
    pcall(function()
        local character = p.Character; local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
        local localCharacter = LocalPlayer.Character; local localRoot = localCharacter and localCharacter:FindFirstChild("HumanoidRootPart")
        if not humanoidRootPart or not localRoot then return end

        local distance = (humanoidRootPart.Position - localRoot.Position).Magnitude
        local transparency = Config.Transparency
        if Config.DistanceFade and distance > 0 then transparency = math.clamp(1 - (distance / Config.MaxDistance), 0.1, 1) end

        for _, data in ipairs(ESP[p].lines) do
            local line = data.line
            if esp_active and distance <= Config.MaxDistance then
                if data.type == "R15" then
                    local p1, o1 = Camera:WorldToViewportPoint(data.part1.Position)
                    local p2, o2 = Camera:WorldToViewportPoint(data.part2.Position)
                    if o1 and o2 then
                        line.From = Vector2.new(p1.X, p1.Y)
                        line.To = Vector2.new(p2.X, p2.Y)
                        line.Transparency = transparency
                        line.Visible = true
                    else line.Visible = false end
                elseif data.type == "R6" then
                    local parts = data.parts
                    local head = parts.Head; local torso = parts.Torso
                    local la = parts.LeftArm; local ra = parts.RightArm
                    local ll = parts.LeftLeg; local rl = parts.RightLeg
                    if head and torso and la and ra and ll and rl then
                        local pFrom, pTo
                        if data.id == 1 then pFrom = head.Position pTo = torso.CFrame * Vector3.new(0, 1, 0)
                        elseif data.id == 2 then pFrom = torso.CFrame * Vector3.new(0, 1, 0) pTo = torso.CFrame * Vector3.new(-1, 1, 0)
                        elseif data.id == 3 then pFrom = torso.CFrame * Vector3.new(0, 1, 0) pTo = torso.CFrame * Vector3.new(1, 1, 0)
                        elseif data.id == 4 then pFrom = torso.CFrame * Vector3.new(-1, 1, 0) pTo = la.Position
                        elseif data.id == 5 then pFrom = torso.CFrame * Vector3.new(1, 1, 0) pTo = ra.Position
                        elseif data.id == 6 then pFrom = torso.CFrame * Vector3.new(0, 1, 0) pTo = torso.CFrame * Vector3.new(0, -1, 0)
                        elseif data.id == 7 then pFrom = torso.CFrame * Vector3.new(0, -1, 0) pTo = torso.CFrame * Vector3.new(-0.5, -1, 0)
                        elseif data.id == 8 then pFrom = torso.CFrame * Vector3.new(0, -1, 0) pTo = torso.CFrame * Vector3.new(0.5, -1, 0)
                        elseif data.id == 9 then pFrom = torso.CFrame * Vector3.new(-0.5, -1, 0) pTo = ll.Position
                        elseif data.id == 10 then pFrom = torso.CFrame * Vector3.new(0.5, -1, 0) pTo = rl.Position end
                        
                        local p1, o1 = Camera:WorldToViewportPoint(pFrom)
                        local p2, o2 = Camera:WorldToViewportPoint(pTo)
                        if o1 and o2 then
                            line.From = Vector2.new(p1.X, p1.Y)
                            line.To = Vector2.new(p2.X, p2.Y)
                            line.Transparency = transparency
                            line.Visible = true
                        else line.Visible = false end
                    else line.Visible = false end
                end
            else line.Visible = false end
        end
    end)
end

function ESP.RemoveESP(p) if ESP[p] then for _, d in ipairs(ESP[p].lines) do d.line:Remove() end ESP[p] = nil end end
Players.PlayerRemoving:Connect(ESP.RemoveESP)
