local function UpdateLists()
    targetList = {}
    for _, p in ipairs(Players:GetPlayers()) do if p ~= player then table.insert(targetList, p) end end
    tpTargetIndex = math.clamp(tpTargetIndex, 1, math.max(1, #targetList))
    flingTargetIndex = math.clamp(flingTargetIndex, 1, math.max(1, #targetList))
    
    if #targetList > 0 then
        TargetPlayerLabel.Text = targetList[tpTargetIndex].DisplayName
        TargetPlayerLabel.TextColor3 = Theme.TextActive
        TargetFlingLabel.Text = "Fling: " .. targetList[flingTargetIndex].DisplayName
        TargetFlingLabel.TextColor3 = Theme.TextActive
    else
        TargetPlayerLabel.Text = "Ninguém Online" TargetPlayerLabel.TextColor3 = Theme.TextMuted
        TargetFlingLabel.Text = "Ninguém Online" TargetFlingLabel.TextColor3 = Theme.TextMuted
    end
end

