    if input.KeyCode == Enum.KeyCode.Space and infjump_active then
        local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
    end
    if input.UserInputType == Enum.UserInputType.MouseButton2 and aimbot_active then aiming = true end
