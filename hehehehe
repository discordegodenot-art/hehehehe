-- Ativação mecânica do Click Teleport através do Mouse
UIS.InputBegan:Connect(function(input, processed)
    if clicktp_active and input.UserInputType == Enum.UserInputType.MouseButton1 then
        -- Verifica se a tecla bindada está sendo segurada
        if UIS:IsKeyDown(Enum.KeyCode[Binds.ClickTP]) and player.Character then
            local hrp = player.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local mouse = player:GetMouse()
                if mouse.Target then
                    -- Teleporta 3 unidades acima do ponto clicado para não bugar no chão
                    hrp.CFrame = CFrame.new(mouse.Hit.Position + Vector3.new(0, 3, 0))
                end
            end
        end
    end
    
    if processed then return end
    if infjump_active and input.KeyCode == Enum.KeyCode.Space then
        local char = player.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
    end
end)

