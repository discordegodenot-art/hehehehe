UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end 
    if input.UserInputType == Enum.UserInputType.Keyboard then
        local keyPressed = input.KeyCode.Name
        if keyPressed == Binds.ESP then ToggleESP()
        elseif keyPressed == Binds.NoClip then ToggleNoClip()
        elseif keyPressed == Binds.Fly then ToggleFly()
        elseif keyPressed == Binds.Invisible then ToggleInvisible()
        elseif keyPressed == Binds.Spectate then ToggleSpectate()
        elseif keyPressed == Binds.Aimbot then ToggleAimbot()
        elseif keyPressed == Binds.Freecam then ToggleFreecam()
        elseif keyPressed == Binds.GodMode then ToggleGodMode()
        elseif keyPressed == Binds.AutoClick then ToggleAutoClick()
        end
    end
end)

local function GetClosestPlayerToCursor()
    local closestPlayer = nil; local shortestDistance = math.huge; local mousePos = UIS:GetMouseLocation()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local targetName = aimbot_part
            if targetName == "Torso" and not p.Character:FindFirstChild("Torso") then targetName = "UpperTorso" end
            local part = p.Character:FindFirstChild(targetName); local humanoid = p.Character:FindFirstChildOfClass("Humanoid")
            if part and humanoid and humanoid.Health > 0 then
                local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local distance = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    if distance < shortestDistance then shortestDistance = distance; closestPlayer = part end
                end
            end
        end
    end
    return closestPlayer
end

