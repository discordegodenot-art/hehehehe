local function UpdateSpectateList()
    targetList = {}
    for _, p in ipairs(Players:GetPlayers()) do if p ~= player then table.insert(targetList, p) end end
    if targetIndex > #targetList then targetIndex = math.max(1, #targetList) end
end

Players.PlayerAdded:Connect(function(p) task.wait(0.5) UpdateSpectateList() end)
Players.PlayerRemoving:Connect(function(p)
    UpdateSpectateList()
    if spectate_active and (not targetList[targetIndex] or targetList[targetIndex] == p) then
        if #targetList > 0 then
            targetIndex = 1
            local targetPlayer = targetList[targetIndex]
            if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChildOfClass("Humanoid") then
                Camera.CameraSubject = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
                SpectateToggleButton.Text = targetPlayer.DisplayName
            end
        else
            spectate_active = false
            local localHumanoid = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
            if localHumanoid then Camera.CameraSubject = localHumanoid end
            SpectateToggleButton.Text = "Espectar"
            SpectateToggleButton.BackgroundColor3 = Theme.BtnDefault
        end
    end
end)

local function ToggleESP()
    esp_active = not esp_active 
    if esp_active then
        ESPToggleButton.Text = "Desativar ESP" ESPToggleButton.BackgroundColor3 = Theme.BtnActive 
        for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer then ESP.CreateESP(p) end end
    else
        ESPToggleButton.Text = "Ativar ESP" ESPToggleButton.BackgroundColor3 = Theme.BtnDefault 
        for _, p in ipairs(Players:GetPlayers()) do ESP.RemoveESP(p) end
    end
end

local function ToggleNoClip()
    noclip_active = not noclip_active 
    if noclip_active then
        NoClipToggleButton.Text = "Desativar NoClip" NoClipToggleButton.BackgroundColor3 = Theme.BtnActive 
    else
        NoClipToggleButton.Text = "Ativar NoClip" NoClipToggleButton.BackgroundColor3 = Theme.BtnDefault 
    end
end

local function ToggleFly()
    fly_active = not fly_active 
    if fly_active then
        FlyToggleButton.Text = "Desativar Voo" FlyToggleButton.BackgroundColor3 = Theme.BtnActive 
    else
        FlyToggleButton.Text = "Ativar Voo" FlyToggleButton.BackgroundColor3 = Theme.BtnDefault 
    end
end

local function ToggleInvisible()
    invisible_active = not invisible_active
    local char = player.Character
    if char then
        if invisible_active then
            InvisibleToggleButton.Text = "Desativar Invisibilidade" InvisibleToggleButton.BackgroundColor3 = Theme.BtnActive
            for _, child in ipairs(char:GetDescendants()) do
                if child:IsA("BasePart") and child.Name ~= "HumanoidRootPart" then child.Transparency = 1
                elseif child:IsA("Decal") or child:IsA("Texture") then child.Transparency = 1 end
            end
        else
            InvisibleToggleButton.Text = "Ativar Invisibilidade" InvisibleToggleButton.BackgroundColor3 = Theme.BtnDefault
            for _, child in ipairs(char:GetDescendants()) do
                if child:IsA("BasePart") and child.Name ~= "HumanoidRootPart" then child.Transparency = 0
                elseif child:IsA("Decal") or child:IsA("Texture") then child.Transparency = 0 end
            end
        end
    end
end

local function ToggleSpectate()
    UpdateSpectateList()
    if #targetList == 0 then SpectateToggleButton.Text = "Sem Alvos" task.wait(1) SpectateToggleButton.Text = "Espectar" return end
    spectate_active = not spectate_active
    if spectate_active then
        if freecam_active then ToggleFreecam() end
        local targetPlayer = targetList[targetIndex]
        if targetPlayer and targetPlayer.Character then
            local targetHumanoid = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
            if targetHumanoid then Camera.CameraSubject = targetHumanoid SpectateToggleButton.Text = targetPlayer.DisplayName SpectateToggleButton.BackgroundColor3 = Theme.BtnActive end
        end
    else
        local localHumanoid = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if localHumanoid then Camera.CameraSubject = localHumanoid end
        SpectateToggleButton.Text = "Espectar" SpectateToggleButton.BackgroundColor3 = Theme.BtnDefault
    end
end

local function ChangeTarget(direction)
    UpdateSpectateList() if #targetList == 0 then return end
    targetIndex = targetIndex + direction
    if targetIndex > #targetList then targetIndex = 1 elseif targetIndex < 1 then targetIndex = #targetList end
    if spectate_active then
        local targetPlayer = targetList[targetIndex]
        if targetPlayer and targetPlayer.Character then
            local targetHumanoid = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
            if targetHumanoid then Camera.CameraSubject = targetHumanoid SpectateToggleButton.Text = targetPlayer.DisplayName end
        end
    end
end

local function ToggleAimbot()
    aimbot_active = not aimbot_active
    if aimbot_active then AimbotToggleButton.Text = "Desativar Aimbot" AimbotToggleButton.BackgroundColor3 = Theme.BtnActive
    else AimbotToggleButton.Text = "Ativar Aimbot" AimbotToggleButton.BackgroundColor3 = Theme.BtnDefault aiming = false end
end

function ToggleFreecam()
    freecam_active = not freecam_active
    if freecam_active then
        FreecamToggleButton.Text = "Desativar Freecam"
        FreecamToggleButton.BackgroundColor3 = Theme.BtnActive
        
        if spectate_active then ToggleSpectate() end
        
        freecam_pos = Camera.CFrame.Position
        local _, y, x = Camera.CFrame:ToOrientation()
        freecam_rotX = x
        freecam_rotY = y
        
        Camera.CameraType = Enum.CameraType.Scriptable
    else
        FreecamToggleButton.Text = "Ativar Freecam"
        FreecamToggleButton.BackgroundColor3 = Theme.BtnDefault
        Camera.CameraType = Enum.CameraType.Custom
        UIS.MouseBehavior = Enum.MouseBehavior.Default
        holding_mouse_look = false
        
        local humanoid = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if humanoid then Camera.CameraSubject = humanoid end
    end
end

local function ToggleGodMode()
    godmode_active = not godmode_active
    if godmode_active then
        GodModeToggleButton.Text = "Desativar God Mode"
        GodModeToggleButton.BackgroundColor3 = Theme.BtnActive
        
        local function ApplyGod()
            local ch = player.Character
            if ch then
                local hum = ch:FindFirstChildOfClass("Humanoid")
                if hum then
                    godConnection = hum.StateChanged:Connect(function(_, state)
                        if state == Enum.HumanoidStateType.Dead then
                            hum:ChangeState(Enum.HumanoidStateType.Running)
                            hum.Health = hum.MaxHealth
                        end
                    end)
                    hum.Health = hum.MaxHealth
                end
            end
        end
        ApplyGod()
        player.CharacterAdded:Connect(ApplyGod)
    else
        GodModeToggleButton.Text = "Ativar God Mode"
        GodModeToggleButton.BackgroundColor3 = Theme.BtnDefault
        if godConnection then
            godConnection:Disconnect()
            godConnection = nil
        end
    end
end

