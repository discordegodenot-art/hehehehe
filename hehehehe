AimbotPartButton.MouseButton1Click:Connect(function()
    aimbot_part = (aimbot_part == "Head") and "Torso" or "Head"
    AimbotPartButton.Text = aimbot_part
end)

UIS.InputBegan:Connect(function(input, processed)
    if freecam_active and input.UserInputType == Enum.UserInputType.MouseButton2 then
        holding_mouse_look = true
        UIS.MouseBehavior = Enum.MouseBehavior.LockCurrentPosition
    end
    if processed then return end
    if input.UserInputType == Enum.UserInputType.MouseButton2 and aimbot_active then aiming = true end
end)

UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton2 then 
        aiming = false 
        if freecam_active then holding_mouse_look = false UIS.MouseBehavior = Enum.MouseBehavior.Default end
    end
end)

UIS.InputChanged:Connect(function(input)
    if freecam_active and holding_mouse_look and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Delta
        freecam_rotX = freecam_rotX - math.rad(delta.X * 0.35)
        freecam_rotY = math.clamp(freecam_rotY - math.rad(delta.Y * 0.35), math.rad(-89), math.rad(89))
    end
end)

