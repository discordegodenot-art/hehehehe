local function GetClosestPlayerToCursor()
    local closestPart = nil local shortestDistance = math.huge local mousePos = UIS:GetMouseLocation()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local tName = aimbot_part
            if tName == "Torso" and not p.Character:FindFirstChild("Torso") then tName = "UpperTorso" end
            local part = p.Character:FindFirstChild(tName)
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if part and hum and hum.Health > 0 then
                local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local distance = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    if distance < shortestDistance and distance <= AimbotFOV.Radius then
                        shortestDistance = distance closestPart = part
                    end
                end
            end
        end
    end
    return closestPart
end

