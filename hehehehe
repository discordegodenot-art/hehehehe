local function UpdateSpectateList()
    targetList = {} for _, p in ipairs(Players:GetPlayers()) do if p ~= player then table.insert(targetList, p) end end
    if targetIndex > #targetList then targetIndex = math.max(1, #targetList) end
end

local function UpdateTPTargetList()
    tpTargetList = {} for _, p in ipairs(Players:GetPlayers()) do if p ~= player then table.insert(tpTargetList, p) end end
    if tpTargetIndex > #tpTargetList then tpTargetIndex = math.max(1, #tpTargetList) end
    if #tpTargetList > 0 then
        TargetPlayerLabel.Text = tpTargetList[tpTargetIndex].DisplayName
        TargetPlayerLabel.TextColor3 = Theme.TextActive
    else
        TargetPlayerLabel.Text = "Ninguém Online"
        TargetPlayerLabel.TextColor3 = Theme.TextMuted
    end
end

local function ChangeTPTarget(direction)
    UpdateTPTargetList() if #tpTargetList == 0 then return end
    tpTargetIndex = tpTargetIndex + direction
    if tpTargetIndex > #tpTargetList then tpTargetIndex = 1 elseif tpTargetIndex < 1 then tpTargetIndex = #tpTargetList end
    TargetPlayerLabel.Text = tpTargetList[tpTargetIndex].DisplayName
end

local function ExecutePlayerTeleport()
    UpdateTPTargetList() if #tpTargetList == 0 then return end
    local selected = tpTargetList[tpTargetIndex]
    if selected and selected.Character and player.Character then
        local targetHRP = selected.Character:FindFirstChild("HumanoidRootPart")
        local myHRP = player.Character:FindFirstChild("HumanoidRootPart")
        if targetHRP and myHRP then
            myHRP.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 2)
        end
    end
end

local function ToggleNoClip()
    noclip_active = not noclip_active 
    NoClipToggleButton.Text = noclip_active and "Desativar NoClip" or "Ativar NoClip"
    NoClipToggleButton.BackgroundColor3 = noclip_active and Theme.BtnActive or Theme.BtnDefault
    if not noclip_active and player.Character then
        for _, part in ipairs(player.Character:GetDescendants()) do if part:IsA("BasePart") then part.CanCollide = true end end
    end
end

local function ToggleFly()
    fly_active = not fly_active 
    FlyToggleButton.Text = fly_active and "Desativar Voo" or "Ativar Voo"
    FlyToggleButton.BackgroundColor3 = fly_active and Theme.BtnActive or Theme.BtnDefault
    if not fly_active and player.Character then
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0) end
    end
end

local function ToggleInvisible()
    invisible_active = not invisible_active
    local char = player.Character
    if char then
        InvisibleToggleButton.Text = invisible_active and "Desativar Invisibilidade" or "Ativar Invisibilidade"
        InvisibleToggleButton.BackgroundColor3 = invisible_active and Theme.BtnActive or Theme.BtnDefault
        for _, child in ipairs(char:GetDescendants()) do
            if child:IsA("BasePart") and child.Name ~= "HumanoidRootPart" then child.Transparency = invisible_active and 1 or 0
            elseif child:IsA("Decal") or child:IsA("Texture") then child.Transparency = invisible_active and 1 or 0 end
        end
    end
end

local function ToggleSpectate()
    UpdateSpectateList()
    if #targetList == 0 then SpectateToggleButton.Text = "Sem Alvos" task.wait(1) SpectateToggleButton.Text = "Espectar" return end
    spectate_active = not spectate_active
    if spectate_active then
        if freecam_active then ToggleFreecam() end
        local targetPlayer = targetList[targetIndex]
        if targetPlayer and targetPlayer.Character then
            local targetHumanoid = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
            if targetHumanoid then Camera.CameraSubject = targetHumanoid SpectateToggleButton.Text = targetPlayer.DisplayName SpectateToggleButton.BackgroundColor3 = Theme.BtnActive end
        end
    else
        local localHumanoid = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if localHumanoid then Camera.CameraSubject = localHumanoid end
        SpectateToggleButton.Text = "Espectar" SpectateToggleButton.BackgroundColor3 = Theme.BtnDefault
    end
end

local function ChangeTarget(direction)
    UpdateSpectateList() if #targetList == 0 then return end
    targetIndex = targetIndex + direction
    if targetIndex > #targetList then targetIndex = 1 elseif targetIndex < 1 then targetIndex = #targetList end
    if spectate_active then
        local targetPlayer = targetList[targetIndex]
        if targetPlayer and targetPlayer.Character then
            local targetHumanoid = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
            if targetHumanoid then Camera.CameraSubject = targetHumanoid SpectateToggleButton.Text = targetPlayer.DisplayName end
        end
    end
end

local function ToggleAimbot()
    aimbot_active = not aimbot_active
    AimbotToggleButton.Text = aimbot_active and "Desativar Aimbot" or "Ativar Aimbot"
    AimbotToggleButton.BackgroundColor3 = aimbot_active and Theme.BtnActive or Theme.BtnDefault
