-- ESP, NOCLIP, FLY, INVISIBLE, SPECTATE, AIMBOT, FREECAM MANTIDOS IDÊNTICOS...
local function CreatePlayerESP(p: Player)
    if p == player then return end
    local function setupChar(char)
        if not esp_active then return end
        if ESP_Storage[p] then pcall(function() ESP_Storage[p]:Destroy() end) end
        local container = Instance.new("Folder")
        container.Name = "ESP_" .. p.Name
        container.Parent = ScreenGui
        ESP_Storage[p] = container
        local highlight = Instance.new("Highlight")
        highlight.FillColor = GetTeamColor(p)
        highlight.FillTransparency = 0.4
        highlight.OutlineColor = Color3.new(1,1,1)
        highlight.Adornee = char
        highlight.Parent = container
        local head = char:WaitForChild("Head", 5)
        if head then
            local billboard = Instance.new("BillboardGui")
            billboard.Size = UDim2.new(0, 200, 0, 50)
            billboard.AlwaysOnTop = true
            billboard.ExtentsOffset = Vector3.new(0, 3, 0)
            billboard.Adornee = head
            billboard.Parent = container
            local textLabel = Instance.new("TextLabel")
            textLabel.Size = UDim2.new(1, 0, 1, 0)
            textLabel.BackgroundTransparency = 1
            textLabel.TextColor3 = GetTeamColor(p)
            textLabel.TextStrokeTransparency = 0.3
            textLabel.Font = Enum.Font.GothamBold
            textLabel.TextSize = 12
            textLabel.Parent = billboard
            local renderConn
            renderConn = RunService.RenderStepped:Connect(function()
                if not esp_active or not char:IsDescendantOf(workspace) or not container.Parent then
                    renderConn:Disconnect()
                    return
                end
                if player.Character and player.Character:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("HumanoidRootPart") then
                    local dist = math.floor((char.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude)
                    textLabel.Text = string.format("%s\n[%d studs]", p.DisplayName, dist)
                end
            end)
        end
    end
    if p.Character then task.spawn(setupChar, p.Character) end
    p.CharacterAdded:Connect(setupChar)
end

local function ToggleESP()
    esp_active = not esp_active
    ESPToggleButton.Text = esp_active and "Desativar ESP" or "Ativar ESP"
    ESPToggleButton.BackgroundColor3 = esp_active and Theme.BtnActive or Theme.BtnDefault
    if esp_active then
        for _, p in ipairs(Players:GetPlayers()) do CreatePlayerESP(p) end
    else
        for p, folder in pairs(ESP_Storage) do pcall(function() folder:Destroy() end) end
        table.clear(ESP_Storage)
    end
end

local function ToggleNoClip()
    noclip_active = not noclip_active
    NoClipToggleButton.Text = noclip_active and "Desativar NoClip" or "Ativar NoClip"
    NoClipToggleButton.BackgroundColor3 = noclip_active and Theme.BtnActive or Theme.BtnDefault
end

local function ToggleFly()
    fly_active = not fly_active
    FlyToggleButton.Text = fly_active and "Desativar Voo" or "Ativar Voo"
    FlyToggleButton.BackgroundColor3 = fly_active and Theme.BtnActive or Theme.BtnDefault
    if not fly_active and player.Character then
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.AssemblyLinearVelocity = Vector3.new(0,0,0) end
    end
end

local function ToggleInvisible()
    invisible_active = not invisible_active
    InvisibleToggleButton.Text = invisible_active and "Desativar Invisibilidade" or "Ativar Invisibilidade"
    InvisibleToggleButton.BackgroundColor3 = invisible_active and Theme.BtnActive or Theme.BtnDefault
    local char = player.Character
    if char then
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                part.Transparency = invisible_active and 1 or 0
            elseif part:IsA("Decal") then
                part.Transparency = invisible_active and 1 or 0
            end
        end
    end
end

