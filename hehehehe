-- SISTEMA DE ESP MODERNO E CORRIGIDO (NATIVO HIGHLIGHT)
--------------------------------------------------------------------------------
local ESP_Storage = {}

local function CreatePlayerESP(p: Player)
    if p == player then return end
    
    local function setupChar(char)
        if not esp_active then return end
        if ESP_Storage[p] then pcall(function() ESP_Storage[p]:Destroy() end) end
        
        local container = Instance.new("Folder")
        container.Name = "ESP_" .. p.Name
        container.Parent = ScreenGui
        ESP_Storage[p] = container
        
        -- Outline/Chams moderno e limpo
        local highlight = Instance.new("Highlight")
        highlight.FillColor = Color3.fromRGB(180, 50, 50)
        highlight.FillTransparency = 0.5
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.OutlineTransparency = 0.2
        highlight.Adornee = char
        highlight.Parent = container
        
        -- Nome e Distância flutuante
        local head = char:WaitForChild("Head", 5)
        if head then
            local billboard = Instance.new("BillboardGui")
            billboard.Size = UDim2.new(0, 200, 0, 50)
            billboard.AlwaysOnTop = true
            billboard.ExtentsOffset = Vector3.new(0, 2.5, 0)
            billboard.Adornee = head
            billboard.Parent = container
            
            local textLabel = Instance.new("TextLabel")
            textLabel.Size = UDim2.new(1, 0, 1, 0)
            textLabel.BackgroundTransparency = 1
            textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            textLabel.TextStrokeTransparency = 0.2
            textLabel.Font = Enum.Font.GothamBold
            textLabel.TextSize = 13
            textLabel.Parent = billboard
            
            local conn
            conn = RunService.RenderStepped:Connect(function()
                if not esp_active or not char:IsDescendantOf(workspace) or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
                    conn:Disconnect()
                    return
                end
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local dist = math.floor((hrp.Position - player.Character.HumanoidRootPart.Position).Magnitude)
                    textLabel.Text = string.format("%s\n[%d studs]", p.DisplayName, dist)
                end
            end)
        end
    end

    if p.Character then task.spawn(setupChar, p.Character) end
    p.CharacterAdded:Connect(setupChar)
end

local function RemovePlayerESP(p: Player)
    if ESP_Storage[p] then
        pcall(function() ESP_Storage[p]:Destroy() end)
        ESP_Storage[p] = nil
    end
end

local function ToggleESP()
    esp_active = not esp_active 
    if esp_active then
        ESPToggleButton.Text = "Desativar ESP" ESPToggleButton.BackgroundColor3 = Theme.BtnActive 
        for _, p in ipairs(Players:GetPlayers()) do CreatePlayerESP(p) end
    else
        ESPToggleButton.Text = "Ativar ESP" ESPToggleButton.BackgroundColor3 = Theme.BtnDefault 
        for p, _ in pairs(ESP_Storage) do RemovePlayerESP(p) end
    end
end

Players.PlayerAdded:Connect(function(p)
    if esp_active then CreatePlayerESP(p) end
end)
Players.PlayerRemoving:Connect(RemovePlayerESP)

