local function ToggleDanceLoop()
    danceloop_active = not danceloop_active
    DanceLoopToggleButton.Text = danceloop_active and "Desativar Loop Dança" or "Loop de Dança (Chat)"
    DanceLoopToggleButton.BackgroundColor3 = danceloop_active and Theme.BtnActive or Theme.BtnDefault
    
    task.spawn(function()
        local dances = {"/e dance", "/e dance2", "/e dance3", "/e wave"}
        local i = 1
        while danceloop_active do
            local textChat = game:GetService("TextChatService")
            if textChat and textChat.ChatInputBarConfiguration.TargetTextChannel then
                textChat.ChatInputBarConfiguration.TargetTextChannel:SendAsync(dances[i])
            else
                local chatEvents = game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents")
                if chatEvents then
                    chatEvents.SayMessageRequest:FireServer(dances[i], "All")
                end
            end
            i = (i % #dances) + 1
            task.wait(2.5)
        end
    end)
end

