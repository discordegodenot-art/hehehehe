    if clicktp_active and input.UserInputType == Enum.UserInputType.MouseButton1 then
        local bindKey = ClickTPBindBox.Text
        local success, keyEnum = pcall(function() return Enum.KeyCode[bindKey] end)
        if success and UIS:IsKeyDown(keyEnum) then
