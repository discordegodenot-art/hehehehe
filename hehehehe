RunService.Heartbeat:Connect(function(delta)
    local char = player.Character local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local fSpeed = tonumber(FlySpeedBox.Text) or 50
    customFlySpeed = fSpeed

    if fly_active and hrp then
        local flyVelocity = Vector3.new(0, 0, 0) local lookCFrame = Camera.CFrame
        if UIS:IsKeyDown(Enum.KeyCode.W) then flyVelocity += lookCFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then flyVelocity -= lookCFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then flyVelocity -= lookCFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then flyVelocity += lookCFrame.RightVector end
        if flyVelocity.Magnitude > 0 then hrp.AssemblyLinearVelocity = flyVelocity.Unit * customFlySpeed else hrp.AssemblyLinearVelocity = Vector3.new(0,0,0) end
    end
    
    if freecam_active then
        local camVelocity = Vector3.new(0, 0, 0) local lookCFrame = Camera.CFrame
        if UIS:IsKeyDown(Enum.KeyCode.W) then camVelocity += lookCFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then camVelocity -= lookCFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then camVelocity -= lookCFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then camVelocity += lookCFrame.RightVector end
        if camVelocity.Magnitude > 0 then freecam_pos += (camVelocity.Unit * delta * customFlySpeed) end
        Camera.CFrame = CFrame.new(freecam_pos) * CFrame.fromEulerAnglesYXZ(freecam_rotY, freecam_rotX, 0)
    end
end)

RunService.RenderStepped:Connect(function()
    FOVCircle.Position = GetScreenCenter()
    local parsedFOV = tonumber(AimbotFOVBox.Text)
    if parsedFOV then FOVCircle.Radius = parsedFOV AimbotFOV.Radius = parsedFOV end

    if aimbot_active and aiming then
        local closest = GetClosestPlayerToCursor()
        if closest then Camera.CFrame = CFrame.new(Camera.CFrame.Position, closest.Position) end
    end
end)

