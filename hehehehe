    if keyName == FlingBindBox.Text then ToggleFling() end
    if keyName == InfJumpBindBox.Text then ToggleInfJump() end
    if keyName == KillAuraBindBox.Text then ToggleKillAura() end
    if keyName == AirWalkBindBox.Text then ToggleAirWalk() end
