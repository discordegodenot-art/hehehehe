UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end 
    if input.UserInputType == Enum.UserInputType.Keyboard then
        local kp = input.KeyCode.Name
        if kp == Binds.ESP then ToggleESP()
        elseif kp == Binds.NoClip then ToggleNoClip()
        elseif kp == Binds.Fly then ToggleFly()
        elseif kp == Binds.Invisible then ToggleInvisible()
        elseif kp == Binds.Spectate then ToggleSpectate()
        elseif kp == Binds.Aimbot then ToggleAimbot()
        elseif kp == Binds.Freecam then ToggleFreecam()
        elseif kp == Binds.GodMode then ToggleGodMode()
        elseif kp == Binds.AutoClick then ToggleAutoClick()
        elseif kp == Binds.NoRecoil then ToggleNoRecoil()
        elseif kp == Binds.FlingTroll then ToggleFling()
        elseif kp == Binds.InfiniteJump then ToggleInfJump()
        elseif kp == Binds.ClickTP then ToggleClickTP()
        end
    end
end)

local function GetClosestPlayerToCursor()
    local closestPlayer = nil local shortestDistance = math.huge local mousePos = UIS:GetMouseLocation()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local targetName = aimbot_part if targetName == "Torso" and not p.Character:FindFirstChild("Torso") then targetName = "UpperTorso" end
            local part = p.Character:FindFirstChild(targetName) local humanoid = p.Character:FindFirstChildOfClass("Humanoid")
            if part and humanoid and humanoid.Health > 0 then
                local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local distance = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    if distance < shortestDistance and distance <= AimbotFOV.Radius then shortestDistance = distance closestPlayer = part end
                end
            end
        end
    end
    return closestPlayer
end

