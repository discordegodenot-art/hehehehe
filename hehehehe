end

function ToggleFreecam()
    freecam_active = not freecam_active
    if freecam_active then
        FreecamToggleButton.Text = "Desativar Freecam" FreecamToggleButton.BackgroundColor3 = Theme.BtnActive
        if spectate_active then ToggleSpectate() end
        freecam_pos = Camera.CFrame.Position local _, y, x = Camera.CFrame:ToOrientation() freecam_rotX = x freecam_rotY = y
        Camera.CameraType = Enum.CameraType.Scriptable
    else
        FreecamToggleButton.Text = "Ativar Freecam" FreecamToggleButton.BackgroundColor3 = Theme.BtnDefault
        Camera.CameraType = Enum.CameraType.Custom UIS.MouseBehavior = Enum.MouseBehavior.Default holding_mouse_look = false
        local humanoid = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if humanoid then Camera.CameraSubject = humanoid end
    end
end

local function ToggleGodMode()
    godmode_active = not godmode_active
    GodModeToggleButton.Text = godmode_active and "Desativar God Mode" or "Ativar God Mode"
    GodModeToggleButton.BackgroundColor3 = godmode_active and Theme.BtnActive or Theme.BtnDefault
    if godmode_active then
        local function ApplyGod()
            local ch = player.Character
            if ch then
                local hum = ch:FindFirstChildOfClass("Humanoid")
                if hum then
                    godConnection = hum.StateChanged:Connect(function(_, state)
                        if state == Enum.HumanoidStateType.Dead then hum:ChangeState(Enum.HumanoidStateType.Running) hum.Health = hum.MaxHealth end
                    end)
                    hum.Health = hum.MaxHealth
                end
            end
        end
        ApplyGod() player.CharacterAdded:Connect(ApplyGod)
    else
        if godConnection then godConnection:Disconnect() godConnection = nil end
    end
end

